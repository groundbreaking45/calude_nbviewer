<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_viewer.xml -->
<!--
    Notebook viewer layout.
    Three mutually-exclusive states are driven by NotebookViewerFragment:
      1. Loading: progressBar VISIBLE, others GONE
      2. Success: recyclerViewCells VISIBLE, others GONE
      3. Error:   textViewError VISIBLE, others GONE
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Loading indicator — centered, shown while parsing -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

    <!--
        Cell list.
        setHasFixedSize(true) is called in Fragment for performance.
        Adapter is assigned in M4.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewCells"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="32dp"
        android:scrollbars="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_cell_placeholder"
        tools:visibility="visible" />

    <!--
        Error state.
        Displays the formatted message from NotebookUiState.Error.
        Centered, readable, no action in v1 (future: retry button).
    -->
    <TextView
        android:id="@+id/textViewError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:gravity="center"
        android:padding="32dp"
        android:textAppearance="?attr/textAppearanceBody1"
        android:textColor="?attr/colorError"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Could not open file."
        tools:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
