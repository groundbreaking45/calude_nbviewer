<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Centered content group -->
    <LinearLayout
        android:id="@+id/home_center_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/home_footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.42">

        <!-- Notebook icon -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_notebook"
            android:contentDescription="Notebook icon"
            android:layout_marginBottom="24dp" />

        <!-- App title -->
        <TextView
            android:id="@+id/home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NbViewer"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:layout_marginBottom="10dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/home_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open any .ipynb file to view its contents offline"
            android:textSize="15sp"
            android:gravity="center"
            android:alpha="0.65"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="40dp" />

        <!-- Open File button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonOpenFile"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="Open File"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:cornerRadius="26dp" />

    </LinearLayout>

    <!-- Footer chips -->
    <LinearLayout
        android:id="@+id/home_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offline"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:alpha="0.55"
            android:background="@drawable/chip_background" />

        <View
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No code execution"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:alpha="0.55"
            android:background="@drawable/chip_background" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>