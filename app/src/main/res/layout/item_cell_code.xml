<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Header row: execution count label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/cell_code_execution_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ ]"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#888888"
            android:minWidth="40dp" />
    </LinearLayout>

    <!-- Source code block with light gray background -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="horizontal"
        android:fillViewport="true"
        android:background="#F8F8F8"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/cell_code_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#1A1A1A"
            android:lineSpacingMultiplier="1.3" />

    </HorizontalScrollView>

    <!-- Output area — hidden when empty -->
    <LinearLayout
        android:id="@+id/cell_code_output_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:visibility="gone" />

</LinearLayout>
