<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!--
        HomeFragment — app launcher start destination.
        No arguments: user initiates file picker from here.
    -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.nbviewer.presentation.home.HomeFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_viewer"
            app:destination="@id/notebookViewerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!--
        NotebookViewerFragment — displays parsed notebook cells.
        Receives sourceUriString from:
          A) HomeFragment (SAF picker result)
          B) MainActivity (ACTION_VIEW intent)
    -->
    <fragment
        android:id="@+id/notebookViewerFragment"
        android:name="com.nbviewer.presentation.viewer.NotebookViewerFragment"
        android:label="@string/viewer_label"
        tools:layout="@layout/fragment_viewer">

        <argument
            android:name="sourceUriString"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

</navigation>
